@prefix biosample: <http://ddbj.nig.ac.jp/ontologies/biosample/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://ddbj.nig.ac.jp/ontologies/biosample/>
    a owl:Ontology ;
    rdfs:label "DDBJ BioSample Ontology" ;
    rdfs:comment "Vocabulary for DDBJ BioSample metadata" .

biosample:status
    a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "INSDC record status: public, private, suppressed, or withdrawn" .

biosample:properties
    a owl:ObjectProperty ;
    rdfs:label "properties" ;
    rdfs:comment "Original XML structure preserved as a JSON object" .

biosample:organism
    a owl:ObjectProperty ;
    rdfs:label "organism" ;
    rdfs:comment "Target organism with taxonomy identifier and scientific name" .

biosample:dbXrefs
    a owl:ObjectProperty ;
    rdfs:label "dbXrefs" ;
    rdfs:comment "Cross-references to related entries in other INSDC databases" .

biosample:organization
    a owl:ObjectProperty ;
    rdfs:label "organization" ;
    rdfs:comment "Submitting organization derived from BioSample Owner.Name; role is always null" .

biosample:model
    a owl:DatatypeProperty ;
    rdfs:label "model" ;
    rdfs:comment "BioSample data model names as a list of strings (e.g. 'MIGS.ba', 'MIGS.eu')" .

biosample:package
    a owl:ObjectProperty ;
    rdfs:label "package" ;
    rdfs:comment "BioSample submission package with name and displayName; NCBI only, DDBJ is always null" .
