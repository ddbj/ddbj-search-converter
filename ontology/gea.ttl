@prefix gea: <http://ddbj.nig.ac.jp/ontologies/gea/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://ddbj.nig.ac.jp/ontologies/gea/>
    a owl:Ontology ;
    rdfs:label "DDBJ GEA Ontology" ;
    rdfs:comment "Vocabulary for DDBJ Genomic Expression Archive metadata" .

gea:status
    a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "INSDC record status: always public for GEA" .

gea:accessibility
    a owl:DatatypeProperty ;
    rdfs:label "accessibility" ;
    rdfs:comment "Access level: always public-access for GEA" .

gea:properties
    a owl:ObjectProperty ;
    rdfs:label "properties" ;
    rdfs:comment "Original IDF tag-value pairs preserved as a JSON object" .

gea:organism
    a owl:ObjectProperty ;
    rdfs:label "organism" ;
    rdfs:comment "Target organism (always null for GEA because IDF does not record organism and SDRF is not joined)" .

gea:dbXrefs
    a owl:ObjectProperty ;
    rdfs:label "dbXrefs" ;
    rdfs:comment "Cross-references to related entries in other databases" .

gea:organization
    a owl:ObjectProperty ;
    rdfs:label "organization" ;
    rdfs:comment "Submitting organization derived from IDF Person Affiliation entries (role is fixed to submitter)" .

gea:publication
    a owl:ObjectProperty ;
    rdfs:label "publication" ;
    rdfs:comment "Publication associated with the GEA study (PubMed ID and Publication DOI stored as separate entries)" .

gea:reference
    a owl:DatatypeProperty ;
    rdfs:label "reference" ;
    rdfs:comment "Publication reference identifier" .

gea:dbType
    a owl:DatatypeProperty ;
    rdfs:label "dbType" ;
    rdfs:comment "Publication database type: pubmed, doi, or pmc" .

gea:experimentType
    a owl:DatatypeProperty ;
    rdfs:label "experimentType" ;
    rdfs:comment "Experiment type from IDF Comment[AEExperimentType] (controlled vocabulary covering Microarray and Sequencing workflows)" .
