@prefix jga: <http://ddbj.nig.ac.jp/ontologies/jga/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://ddbj.nig.ac.jp/ontologies/jga/>
    a owl:Ontology ;
    rdfs:label "DDBJ JGA Ontology" ;
    rdfs:comment "Vocabulary for DDBJ Japanese Genotype-phenotype Archive metadata" .

jga:status
    a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "INSDC record status: always public for JGA" .

jga:properties
    a owl:ObjectProperty ;
    rdfs:label "properties" ;
    rdfs:comment "Original XML structure preserved as a JSON object" .

jga:organism
    a owl:ObjectProperty ;
    rdfs:label "organism" ;
    rdfs:comment "Target organism with taxonomy identifier and scientific name (Homo sapiens for jga-study and jga-dataset; null for jga-dac and jga-policy)" .

jga:dbXrefs
    a owl:ObjectProperty ;
    rdfs:label "dbXrefs" ;
    rdfs:comment "Cross-references to related entries in other INSDC databases" .

jga:organization
    a owl:ObjectProperty ;
    rdfs:label "organization" ;
    rdfs:comment "Submitting organization from @center_name, the STUDY_ATTRIBUTES TAG='Submitting organization' VALUE (jga-study), and CONTACTS/CONTACT@organisation (jga-dac)" .

jga:publication
    a owl:ObjectProperty ;
    rdfs:label "publication" ;
    rdfs:comment "Publication associated with the JGA study" .

jga:reference
    a owl:DatatypeProperty ;
    rdfs:label "reference" ;
    rdfs:comment "Publication reference identifier" .

jga:dbType
    a owl:DatatypeProperty ;
    rdfs:label "dbType" ;
    rdfs:comment "Publication database type: pubmed, doi, or pmc (JGA populates pubmed only)" .

jga:grant
    a owl:ObjectProperty ;
    rdfs:label "grant" ;
    rdfs:comment "Funding grant associated with the JGA study" .

jga:agency
    a owl:ObjectProperty ;
    rdfs:label "agency" ;
    rdfs:comment "Funding agency for a grant, represented as an Organization." .

jga:externalLink
    a owl:ObjectProperty ;
    rdfs:label "externalLink" ;
    rdfs:comment "External link from STUDY_LINKS / DAC_LINKS / POLICY_LINKS URL_LINK elements" .

jga:studyType
    a owl:DatatypeProperty ;
    rdfs:label "studyType" ;
    rdfs:comment "Study type from STUDY_TYPES/STUDY_TYPE (existing_study_type, or new_study_type when existing=Other)" .

jga:datasetType
    a owl:DatatypeProperty ;
    rdfs:label "datasetType" ;
    rdfs:comment "Dataset type from DATASET_TYPE element" .

jga:vendor
    a owl:DatatypeProperty ;
    rdfs:label "vendor" ;
    rdfs:comment "Sequencing vendor from STUDY_ATTRIBUTES TAG='Vendor' VALUE" .
