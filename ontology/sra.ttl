@prefix sra: <http://ddbj.nig.ac.jp/ontologies/sra/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://ddbj.nig.ac.jp/ontologies/sra/>
    a owl:Ontology ;
    rdfs:label "DDBJ SRA Ontology" ;
    rdfs:comment "Vocabulary for DDBJ Sequence Read Archive metadata" .

sra:status
    a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "INSDC record status: public, private, suppressed, or withdrawn" .

sra:properties
    a owl:ObjectProperty ;
    rdfs:label "properties" ;
    rdfs:comment "Original XML structure preserved as a JSON object" .

sra:organism
    a owl:ObjectProperty ;
    rdfs:label "organism" ;
    rdfs:comment "Target organism with taxonomy identifier and scientific name" .

sra:dbXrefs
    a owl:ObjectProperty ;
    rdfs:label "dbXrefs" ;
    rdfs:comment "Cross-references to related entries in other INSDC databases" .

sra:organization
    a owl:ObjectProperty ;
    rdfs:label "organization" ;
    rdfs:comment "Submitting organization derived from @center_name; role and organizationType are always null" .

sra:publication
    a owl:ObjectProperty ;
    rdfs:label "publication" ;
    rdfs:comment "Publication derived from *_LINKS/XREF_LINK where DB is pubmed (case-insensitive)" .

sra:reference
    a owl:DatatypeProperty ;
    rdfs:label "reference" ;
    rdfs:comment "Publication reference identifier within the shared Publication type" .

sra:dbType
    a owl:DatatypeProperty ;
    rdfs:label "dbType" ;
    rdfs:comment "Publication database type: ePubmed, eDOI, ePMC, or eNotAvailable (SRA populates ePubmed only)" .

sra:libraryStrategy
    a owl:DatatypeProperty ;
    rdfs:label "libraryStrategy" ;
    rdfs:comment "INSDC LIBRARY_STRATEGY (experiment only; controlled vocabulary with 43+ values such as WGS, AMPLICON, RNA-Seq)" .

sra:librarySource
    a owl:DatatypeProperty ;
    rdfs:label "librarySource" ;
    rdfs:comment "INSDC LIBRARY_SOURCE (experiment only; 9 controlled values: GENOMIC, METAGENOMIC, TRANSCRIPTOMIC, VIRAL RNA, OTHER, METATRANSCRIPTOMIC, TRANSCRIPTOMIC SINGLE CELL, GENOMIC SINGLE CELL, SYNTHETIC)" .

sra:librarySelection
    a owl:DatatypeProperty ;
    rdfs:label "librarySelection" ;
    rdfs:comment "INSDC LIBRARY_SELECTION (experiment only; controlled vocabulary with 31+ values such as PCR, RANDOM, cDNA)" .

sra:libraryLayout
    a owl:DatatypeProperty ;
    rdfs:label "libraryLayout" ;
    rdfs:comment "INSDC LIBRARY_LAYOUT (experiment only; 2 values: PAIRED or SINGLE)" .

sra:platform
    a owl:DatatypeProperty ;
    rdfs:label "platform" ;
    rdfs:comment "INSDC PLATFORM (experiment only; 20 controlled values: ILLUMINA, OXFORD_NANOPORE, PACBIO_SMRT, ION_TORRENT, LS454, CAPILLARY, DNBSEQ, BGISEQ, ELEMENT, ABI_SOLID, COMPLETE_GENOMICS, HELICOS, ULTIMA, GENEMIND, VELA_DIAGNOSTICS, TAPESTRI, GENAPSYS, SINGULAR_GENOMICS, GENEUS_TECH, SALUS)" .

sra:instrumentModel
    a owl:DatatypeProperty ;
    rdfs:label "instrumentModel" ;
    rdfs:comment "INSDC INSTRUMENT_MODEL (experiment only; natural-language strings such as 'Illumina NovaSeq 6000')" .

sra:analysisType
    a owl:DatatypeProperty ;
    rdfs:label "analysisType" ;
    rdfs:comment "INSDC ANALYSIS_TYPE parent key (analysis only; 4 controlled values: DE_NOVO_ASSEMBLY, REFERENCE_ALIGNMENT, ABUNDANCE_MEASUREMENT, SEQUENCE_ANNOTATION)" .
